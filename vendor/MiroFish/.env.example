# ===== 默认本地模式 =====
# 在 OKX Local App 内集成时，默认直接复用 Codex CLI 和本地图谱存储，
# 不需要额外配置 LLM_API_KEY / ZEP_API_KEY。
MIROFISH_LLM_BACKEND=codex
MIROFISH_GRAPH_BACKEND=local
MIROFISH_CODEX_COMMAND=codex
MIROFISH_CODEX_MODEL=
MIROFISH_CODEX_TIMEOUT_SECONDS=240

# ===== 可选：切回 OpenAI 兼容 API =====
# 只有在你明确想改回外部 LLM 服务时再填写下面这些配置。
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== 可选：切回 Zep 图谱 =====
# 只有在你明确想改回 Zep 图谱时再填写。
ZEP_API_KEY=

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env 文件中就不要出现下面的配置项。
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=
