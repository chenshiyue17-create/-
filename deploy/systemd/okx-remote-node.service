[Unit]
Description=OKX Local App Remote Execution Node
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/okx-local-app
EnvironmentFile=-/etc/okx-remote-node.env
ExecStart=/opt/okx-local-app/scripts/start-remote-node.sh
Restart=always
RestartSec=3
User=ecs-assist-user
Group=ecs-assist-user

[Install]
WantedBy=multi-user.target
